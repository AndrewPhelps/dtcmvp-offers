# dtcmvp-offers frontend — nginx site config
# Target path on droplet: /etc/nginx/sites-available/dtcmvp-offers
# Enable:   ln -s /etc/nginx/sites-available/dtcmvp-offers /etc/nginx/sites-enabled/
# Reload:   systemctl reload nginx
#
# SSL is added by certbot after this file is in place:
#   certbot --nginx -d offers.dtcmvp.com
# Certbot edits this file to add the "listen 443 ssl" block + HTTP→HTTPS redirect.

server {
    server_name offers.dtcmvp.com;

    location / {
        proxy_pass http://127.0.0.1:3005;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    listen 80;
}
