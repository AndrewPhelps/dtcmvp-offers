# dtcmvp-offers production env — copy to .env.production on the DO droplet.
# .env.production is gitignored. No secrets live here — only public URLs.
# Auth follows dtcmvp-2.0's proxy pattern: the frontend never talks to
# Supabase directly; all auth calls hit NEXT_PUBLIC_AUTH_API_URL, which
# is a FastAPI service on api.dtcmvpete.com that wraps Supabase server-side.

# Backend base URL for /api/offers/* (served by webhook-server-v2)
NEXT_PUBLIC_API_URL=https://webhooks.dtcmvp.com/api

# Public URL of this app
NEXT_PUBLIC_APP_URL=https://offers.dtcmvp.com

# Auth API (dtcmvpete FastAPI handles OTP + session + brand login).
# Server-side only — the /api/auth/* route handler in Next.js proxies
# browser requests here, so the browser never talks to it directly.
AUTH_API_URL=https://api.dtcmvpete.com

# Slack bot token — used by the 1800dtc/run-monthly.sh host cron to post
# the monthly scrape digest. Same token as dtcmvp-app's SLACK_BOT_TOKEN
# (must be in the target channel — default C08QRA47JMD = #dtcmvp-mvc).
# Leave blank in the container itself; the cron wrapper reads the variable
# from this file if populated.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_DIGEST_CHANNEL=C08QRA47JMD
